# Example Environment Configuration
# Copy this file to .env and fill in your actual API keys

# AI/ML API Configuration
# Get your API key from: https://aimlapi.com/
AIMLAPI_KEY=your_aimlapi_key_here

# ChromaDB Cloud Configuration
# Get these credentials from: https://www.trychroma.com/
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_id_here
CHROMA_DATABASE=rag_documents

# Optional: Google AI API (for archived versions)
# GOOGLE_API_KEY=your_google_api_key_here